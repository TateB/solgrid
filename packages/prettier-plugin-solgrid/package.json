{
  "name": "prettier-plugin-solgrid",
  "version": "0.0.11",
  "description": "Prettier plugin for Solidity — powered by solgrid's Rust formatter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TateB/solgrid",
    "directory": "packages/prettier-plugin-solgrid"
  },
  "type": "module",
  "main": "src/index.mjs",
  "files": [
    "src",
    "index.d.ts"
  ],
  "scripts": {
    "build:napi": "napi build --release --cargo-cwd ../../crates/solgrid_napi",
    "build:napi:debug": "napi build --cargo-cwd ../../crates/solgrid_napi",
    "test": "vitest run",
    "test:conformance": "vitest run test/conformance/",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@solgrid/napi-darwin-arm64": "workspace:*",
    "@solgrid/napi-linux-arm64": "workspace:*",
    "@solgrid/napi-linux-x64": "workspace:*",
    "@solgrid/napi-win32-x64": "workspace:*"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "prettier": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
