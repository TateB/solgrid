{
  "name": "solgrid-vscode",
  "displayName": "solgrid",
  "description": "Solidity linter and formatter — powered by solgrid",
  "version": "0.0.3",
  "publisher": "solgrid",
  "license": "MIT",
  "homepage": "https://github.com/TateB/solgrid#readme",
  "bugs": {
    "url": "https://github.com/TateB/solgrid/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TateB/solgrid"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters",
    "Formatters",
    "Programming Languages"
  ],
  "keywords": [
    "solidity",
    "linter",
    "formatter",
    "smart-contracts",
    "ethereum"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "solgrid",
      "properties": {
        "solgrid.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable solgrid linting and formatting."
        },
        "solgrid.path": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Path to the solgrid binary. If null, uses the bundled binary or searches PATH."
        },
        "solgrid.fixOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Auto-fix safe lint issues on save."
        },
        "solgrid.fixOnSave.unsafeFixes": {
          "type": "boolean",
          "default": false,
          "description": "Also apply suggestion-level (unsafe) fixes on save."
        },
        "solgrid.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Format the file on save."
        },
        "solgrid.configPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Path to solgrid.toml. If null, auto-discovers from workspace root."
        }
      }
    },
    "languages": [
      {
        "id": "solidity",
        "extensions": [
          ".sol"
        ],
        "aliases": [
          "Solidity"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "solidity",
        "scopeName": "source.solidity",
        "path": "./syntaxes/solidity.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "node esbuild.mjs --production",
    "compile:dev": "node esbuild.mjs",
    "compile:tests": "tsc -p ./ && tsc -p ./tsconfig.test.json",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run --project unit",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project lsp-integration",
    "test:e2e": "pnpm run compile:tests && node out/test/e2e/run.js",
    "test:all": "pnpm test:unit && pnpm test:integration",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies",
    "package:target": "vsce package --no-dependencies --target",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
