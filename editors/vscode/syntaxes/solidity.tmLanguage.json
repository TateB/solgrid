{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Solidity",
  "scopeName": "source.solidity",
  "patterns": [
    { "include": "#comments" },
    { "include": "#natspec" },
    { "include": "#pragma" },
    { "include": "#import" },
    { "include": "#declaration" },
    { "include": "#expression" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.solidity",
          "match": "//.*$"
        },
        {
          "name": "comment.block.solidity",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "natspec": {
      "patterns": [
        {
          "name": "comment.block.documentation.solidity",
          "begin": "/\\*\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "storage.type.annotation.solidity",
              "match": "(@title|@author|@notice|@dev|@param|@return|@inheritdoc|@custom:\\w+)"
            }
          ]
        },
        {
          "name": "comment.line.documentation.solidity",
          "match": "(///)(.*$)",
          "captures": {
            "1": { "name": "comment.line.documentation.solidity" },
            "2": {
              "patterns": [
                {
                  "name": "storage.type.annotation.solidity",
                  "match": "(@title|@author|@notice|@dev|@param|@return|@inheritdoc|@custom:\\w+)"
                },
                {
                  "name": "comment.line.documentation.solidity",
                  "match": "."
                }
              ]
            }
          }
        }
      ]
    },
    "pragma": {
      "patterns": [
        {
          "name": "meta.pragma.solidity",
          "match": "\\b(pragma)\\s+(solidity|abicoder|experimental)\\b([^;]*)(;)",
          "captures": {
            "1": { "name": "keyword.control.pragma.solidity" },
            "2": { "name": "entity.name.tag.pragma.solidity" },
            "3": { "name": "string.unquoted.pragma.solidity" },
            "4": { "name": "punctuation.terminator.solidity" }
          }
        }
      ]
    },
    "import": {
      "patterns": [
        {
          "name": "keyword.control.import.solidity",
          "match": "\\b(import)\\b"
        },
        {
          "name": "keyword.control.from.solidity",
          "match": "\\b(from)\\b"
        },
        {
          "name": "keyword.other.as.solidity",
          "match": "\\b(as)\\b"
        }
      ]
    },
    "declaration": {
      "patterns": [
        { "include": "#contract-declaration" },
        { "include": "#function-declaration" },
        { "include": "#event-declaration" },
        { "include": "#error-declaration" },
        { "include": "#enum-declaration" },
        { "include": "#struct-declaration" },
        { "include": "#modifier-declaration" },
        { "include": "#type-declaration" },
        { "include": "#using-declaration" },
        { "include": "#storage-keywords" },
        { "include": "#control-flow" },
        { "include": "#type-keywords" },
        { "include": "#modifiers" },
        { "include": "#assembly" }
      ]
    },
    "contract-declaration": {
      "patterns": [
        {
          "match": "\\b(contract|library|interface|abstract)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.contract.solidity" },
            "2": { "name": "entity.name.type.contract.solidity" }
          }
        },
        {
          "name": "keyword.other.inheritance.solidity",
          "match": "\\b(is)\\b"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "match": "\\b(function)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.solidity" },
            "2": { "name": "entity.name.function.solidity" }
          }
        },
        {
          "match": "\\b(constructor|receive|fallback)\\b",
          "name": "keyword.declaration.function.solidity"
        }
      ]
    },
    "event-declaration": {
      "patterns": [
        {
          "match": "\\b(event)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.event.solidity" },
            "2": { "name": "entity.name.type.event.solidity" }
          }
        },
        {
          "name": "keyword.other.emit.solidity",
          "match": "\\b(emit)\\b"
        }
      ]
    },
    "error-declaration": {
      "patterns": [
        {
          "match": "\\b(error)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.error.solidity" },
            "2": { "name": "entity.name.type.error.solidity" }
          }
        }
      ]
    },
    "enum-declaration": {
      "patterns": [
        {
          "match": "\\b(enum)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.enum.solidity" },
            "2": { "name": "entity.name.type.enum.solidity" }
          }
        }
      ]
    },
    "struct-declaration": {
      "patterns": [
        {
          "match": "\\b(struct)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.struct.solidity" },
            "2": { "name": "entity.name.type.struct.solidity" }
          }
        }
      ]
    },
    "modifier-declaration": {
      "patterns": [
        {
          "match": "\\b(modifier)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.modifier.solidity" },
            "2": { "name": "entity.name.function.modifier.solidity" }
          }
        }
      ]
    },
    "type-declaration": {
      "patterns": [
        {
          "match": "\\b(type)\\s+([A-Za-z_]\\w*)\\s+(is)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.type.solidity" },
            "2": { "name": "entity.name.type.solidity" },
            "3": { "name": "keyword.other.is.solidity" }
          }
        }
      ]
    },
    "using-declaration": {
      "patterns": [
        {
          "name": "keyword.other.using.solidity",
          "match": "\\b(using)\\b"
        },
        {
          "name": "keyword.other.for.solidity",
          "match": "\\b(for)\\b"
        },
        {
          "name": "keyword.other.global.solidity",
          "match": "\\bglobal\\b"
        }
      ]
    },
    "storage-keywords": {
      "patterns": [
        {
          "name": "keyword.other.storage.solidity",
          "match": "\\b(mapping|storage|memory|calldata|immutable|constant)\\b"
        }
      ]
    },
    "control-flow": {
      "patterns": [
        {
          "name": "keyword.control.flow.solidity",
          "match": "\\b(if|else|for|while|do|break|continue|return|try|catch|revert|throw|unchecked)\\b"
        },
        {
          "name": "keyword.other.delete.solidity",
          "match": "\\b(delete|new)\\b"
        }
      ]
    },
    "type-keywords": {
      "patterns": [
        {
          "name": "support.type.primitive.solidity",
          "match": "\\b(address|bool|string|bytes|byte|int|uint|fixed|ufixed)(8|16|24|32|40|48|56|64|72|80|88|96|104|112|120|128|136|144|152|160|168|176|184|192|200|208|216|224|232|240|248|256)?\\b"
        },
        {
          "name": "keyword.type.payable.solidity",
          "match": "\\bpayable\\b"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "name": "keyword.modifier.visibility.solidity",
          "match": "\\b(public|private|internal|external)\\b"
        },
        {
          "name": "keyword.modifier.mutability.solidity",
          "match": "\\b(pure|view|payable|nonpayable)\\b"
        },
        {
          "name": "keyword.modifier.misc.solidity",
          "match": "\\b(virtual|override|abstract|indexed|anonymous)\\b"
        },
        {
          "name": "keyword.other.returns.solidity",
          "match": "\\b(returns)\\b"
        }
      ]
    },
    "assembly": {
      "patterns": [
        {
          "name": "keyword.control.assembly.solidity",
          "begin": "\\b(assembly)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.assembly.solidity" }
          },
          "end": "(?=\\{)",
          "patterns": [
            {
              "name": "string.quoted.double.solidity",
              "match": "\"[^\"]*\""
            }
          ]
        }
      ]
    },
    "expression": {
      "patterns": [
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#operators" },
        { "include": "#global-variables" },
        { "include": "#function-call" },
        { "include": "#punctuation" }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.solidity",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.solidity",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.solidity",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.solidity",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.hex.solidity",
          "match": "\\b(hex)\"[0-9a-fA-F_]*\"",
          "captures": {
            "1": { "name": "keyword.other.hex.solidity" }
          }
        },
        {
          "name": "string.quoted.hex.solidity",
          "match": "\\b(hex)'[0-9a-fA-F_]*'",
          "captures": {
            "1": { "name": "keyword.other.hex.solidity" }
          }
        },
        {
          "name": "string.quoted.unicode.solidity",
          "match": "\\b(unicode)\"[^\"]*\"",
          "captures": {
            "1": { "name": "keyword.other.unicode.solidity" }
          }
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex.solidity",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.decimal.solidity",
          "match": "\\b\\d[\\d_]*(\\.[\\d_]+)?([eE][+-]?[\\d_]+)?\\b"
        },
        {
          "name": "keyword.other.unit.solidity",
          "match": "\\b(wei|gwei|ether|seconds|minutes|hours|days|weeks)\\b"
        }
      ]
    },
    "boolean": {
      "patterns": [
        {
          "name": "constant.language.boolean.solidity",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.solidity",
          "match": "(=>|:=|=)"
        },
        {
          "name": "keyword.operator.comparison.solidity",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.solidity",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.solidity",
          "match": "(\\+\\+|--|\\*\\*|\\+|\\-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.solidity",
          "match": "(\\^|&|\\||~|<<|>>)"
        },
        {
          "name": "keyword.operator.ternary.solidity",
          "match": "\\?"
        }
      ]
    },
    "global-variables": {
      "patterns": [
        {
          "name": "variable.language.transaction.solidity",
          "match": "\\b(msg\\.sender|msg\\.value|msg\\.data|msg\\.sig|msg\\.gas)\\b"
        },
        {
          "name": "variable.language.transaction.solidity",
          "match": "\\b(tx\\.origin|tx\\.gasprice)\\b"
        },
        {
          "name": "variable.language.block.solidity",
          "match": "\\b(block\\.(coinbase|difficulty|prevrandao|gaslimit|number|timestamp|chainid|basefee|blobbasefee))\\b"
        },
        {
          "name": "variable.language.this.solidity",
          "match": "\\b(this|super)\\b"
        },
        {
          "name": "support.function.global.solidity",
          "match": "\\b(abi\\.(encode|encodePacked|encodeWithSelector|encodeWithSignature|encodeCall|decode))\\b"
        },
        {
          "name": "support.function.global.solidity",
          "match": "\\b(keccak256|sha256|ripemd160|ecrecover|addmod|mulmod|selfdestruct|blockhash|gasleft)\\b"
        },
        {
          "name": "support.function.require.solidity",
          "match": "\\b(require|assert)\\b"
        },
        {
          "name": "support.type.solidity",
          "match": "\\b(type)\\s*\\("
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_]\\w*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.solidity" }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.solidity",
          "match": ";"
        },
        {
          "name": "punctuation.separator.solidity",
          "match": ","
        }
      ]
    }
  }
}
